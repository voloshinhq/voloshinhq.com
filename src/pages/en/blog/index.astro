---
const target = '/blog';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={"0; url=" + target} />
    <link rel="canonical" href={target} />
    <title>Blog</title>
  </head>
  <body><p><a href={target}>Open blog</a></p></body>
</html>
