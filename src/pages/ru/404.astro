---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="ru"
  title="Страница не найдена"
  description="Эта страница не существует или была перемещена."
  robots="noindex"
>
  <section class="container section not-found">
    <div class="statement reveal">
      <span>404</span>
      <h1>Страница не найдена</h1>
      <p>Возможно, ссылка устарела или адрес введён с ошибкой. Попробуйте главную страницу или блог.</p>
      <div class="cta-actions">
        <a class="button primary" href="/ru">Главная</a>
        <a class="button ghost" href="/ru/blog">Блог</a>
        <a class="button ghost" href="/ru/#contact">Контакт</a>
      </div>
    </div>
  </section>
  <script is:inline>
    (function () {
      var switcher = document.querySelector('[data-lang-switch]');
      if (!switcher) return;
      var path = window.location.pathname || '/ru';
      var target = path.replace(/^\/ru(?=\/|$)/, '') || '/';
      switcher.setAttribute('href', target);
    })();
  </script>
</BaseLayout>
