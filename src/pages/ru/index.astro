---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SocialIcon from '../../components/SocialIcon.astro';
import { calMeetingHref, ctaTelegramHref, emailAddress, emailHref, pathForLang, socialLinks, ui } from '../../data/site';
import { publishedPosts } from '../../data/utils';
import { personSchema, websiteSchema } from '../../data/seo';

const lang = 'ru';
const copy = ui[lang];
const posts = publishedPosts(await getCollection('blog'), lang).slice(0, 3);
---

<BaseLayout lang={lang} structuredData={[personSchema(lang), websiteSchema(lang)]}>
  <section class="hero container">
    <img class="avatar hero-avatar reveal" src="/avatar.jpg" alt="Yaroslav Voloshin" />
    <div class="hero-copy reveal">
      <h1>{copy.hero.title}</h1>
      <p class="lead">{copy.hero.text}</p>
      <div class="social-row hero-social" aria-label="Social links">
        {socialLinks(lang).map((item) => (
          <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined} title={item.label} aria-label={item.label}>
            <SocialIcon name={item.key} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="statement reveal">
      <span>{copy.shift.label}</span>
      <h2>{copy.shift.title}</h2>
      <p>{copy.shift.text}</p>
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <h2>{copy.modes.title}</h2>
    </div>
    <div class="mode-grid">
      {copy.modes.items.map((item) => (
        <article class="card reveal">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container section" id="projects">
    <div class="section-head">
      <h2>{copy.projects.title}</h2>
      <p>{copy.projects.intro}</p>
    </div>
    <div class="project-list">
      {copy.projects.items.map((project) => (
        <article class="project-row reveal">
          <div>
            <h3><a href={project.href}>{project.title}</a></h3>
            <p>{project.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <h2>{copy.testimonials.title}</h2>
    </div>
    <div class="testimonial-grid">
      {copy.testimonials.items.map((item) => (
        <article class="quote-card reveal">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-head row-head">
      <h2>{copy.latest.title}</h2>
      <a class="text-link" href={pathForLang(lang, '/blog')}>{copy.latest.all}</a>
    </div>
    <div class="post-grid">
      {posts.map((post) => <PostCard post={post} lang={lang} />)}
    </div>
  </section>

  <section class="container section" id="contact">
    <div class="cta reveal">
      <h2>{copy.cta.title}</h2>
      <p>{copy.cta.text}</p>
      <p class="contact-email">{copy.cta.emailLabel}: <a href={emailHref}>{emailAddress}</a></p>
      <div class="cta-actions">
        <a class="button primary" href={ctaTelegramHref} target="_blank" rel="noopener">{copy.cta.primary}</a>
        <a
          class="button ghost"
          href={calMeetingHref}
          data-cal-link="voloshinhq/30min"
          data-cal-namespace="30min"
          data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
        >
          {copy.cta.tertiary}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
