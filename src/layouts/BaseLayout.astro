---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../data/site';
import { ui } from '../data/site';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  structuredData?: unknown;
}

const { lang, title, description, image, ogType = 'website', robots, structuredData } = Astro.props;
const copy = ui[lang];
const pageTitle = title ? `${title} — Yaroslav Voloshin` : copy.metaTitle;
const pageDescription = description ?? copy.metaDescription;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const pageImage = new URL(image ?? '/avatar.jpg', Astro.site).toString();
const enPath = lang === 'ru' ? (Astro.url.pathname === '/ru' ? '/' : Astro.url.pathname.replace(/^\/ru/, '')) : Astro.url.pathname;
const ruPath = lang === 'ru' ? Astro.url.pathname : (Astro.url.pathname === '/' ? '/ru' : `/ru${Astro.url.pathname}`);
const enUrl = new URL(enPath, Astro.site).toString();
const ruUrl = new URL(ruPath, Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="ru" href={ruUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:site_name" content="Yaroslav Voloshin" />
    <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/jpeg" href="/avatar.jpg" />
    <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          if (saved === 'dark' || saved === 'light') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (_) {}
      })();
    </script>
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    {lang === 'en' && Astro.url.pathname === '/' && (
      <script is:inline>
        {`
          (function () {
            try {
              if (localStorage.getItem('language-choice')) return;
              var languages = navigator.languages && navigator.languages.length ? navigator.languages : [navigator.language];
              var wantsRussian = languages.some(function (item) { return /^ru\\b/i.test(item || ''); });
              if (wantsRussian) window.location.replace('/ru');
            } catch (_) {}
          })();
        `}
      </script>
    )}
  </head>
  <body>
    <Header lang={lang} pathname={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <script is:inline src="/theme.js"></script>
    <script is:inline src="/site.js?v=20260607-2"></script>
  </body>
</html>
